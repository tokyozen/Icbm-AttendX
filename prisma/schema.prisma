generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  CLOSED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FLAGGED
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(INSTRUCTOR)
  location     String?
  learningTrack String?  @map("learning_track")
  isActive     Boolean   @default(false) @map("is_active")
  isApproved   Boolean   @default(false) @map("is_approved")
  appliedAt    DateTime? @map("applied_at")
  approvedAt   DateTime? @map("approved_at")
  approvedBy   String?   @map("approved_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions TrainingSession[]

  @@map("users")
}

model Student {
  id               String   @id @default(uuid())
  applicationId    String   @unique @map("application_id")
  fullName         String   @map("full_name")
  gender           Gender
  trainingLocation String   @map("training_location")
  learningTrack    String   @map("learning_track")
  email            String?  @map("email")
  phoneNumber      String?  @map("phone_number")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  attendanceRecords AttendanceRecord[]

  @@map("students")
}

model TrainingSession {
  id            String        @id @default(uuid())
  sessionName   String        @map("session_name")
  sessionCode   String        @unique @map("session_code")
  location      String
  learningTrack String        @map("learning_track")
  instructorId  String        @map("instructor_id")
  qrToken       String        @unique @map("qr_token")
  startedAt     DateTime      @map("started_at")
  expiresAt     DateTime      @map("expires_at")
  endedAt       DateTime?     @map("ended_at")
  status        SessionStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")

  instructor        User               @relation(fields: [instructorId], references: [id])
  attendanceRecords AttendanceRecord[]

  @@map("training_sessions")
}

model AttendanceRecord {
  id                 String             @id @default(uuid())
  sessionId          String             @map("session_id")
  studentId          String             @map("student_id")
  applicationId      String             @map("application_id")
  fullName           String             @map("full_name")
  gender             String
  trainingLocation   String             @map("training_location")
  learningTrack      String             @map("learning_track")
  checkInTime        DateTime           @default(now()) @map("check_in_time")
  deviceType         String?            @map("device_type")
  browser            String?
  ipAddress          String?            @map("ip_address")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?          @map("verified_at")
  verifiedBy         String?            @map("verified_by")
  createdAt          DateTime           @default(now()) @map("created_at")

  session TrainingSession @relation(fields: [sessionId], references: [id])
  student Student         @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}
